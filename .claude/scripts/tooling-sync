#!/usr/bin/env bash
# tooling-sync — move the AI dev tooling (.claude/ + CLAUDE.md) between the working
# copy on disk and its git home, the orphan `dev-tooling` branch.
#
# Those files are gitignored on `main` and `frontier` (so they never get swept into a
# feature commit or leak into a PR to main), yet still versioned — on `dev-tooling`,
# which is never merged. This script is the two-way sync.
#
#   tooling-sync pull                 refresh on-disk .claude/ + CLAUDE.md from dev-tooling
#   tooling-sync save ["message"]     commit the on-disk tooling to dev-tooling and push
#   tooling-sync status               show what would be committed by `save`
#
# Run from the repo root (or any subdir; it cd's to the toplevel).
set -euo pipefail

BRANCH=dev-tooling
REMOTE=origin
PATHS=(.claude CLAUDE.md)

cd "$(git rev-parse --show-toplevel)"

die() { echo "tooling-sync: $*" >&2; exit 1; }
git show-ref --verify --quiet "refs/heads/$BRANCH" \
  || git show-ref --verify --quiet "refs/remotes/$REMOTE/$BRANCH" \
  || die "branch '$BRANCH' not found locally or on '$REMOTE'"

cmd="${1:-}"; shift || true
case "$cmd" in
  pull)
    # Extract the tree from dev-tooling straight to disk — no index interaction, so the
    # files stay untracked/ignored on the current branch. Does not delete local extras.
    ref="$BRANCH"; git show-ref --verify --quiet "refs/heads/$BRANCH" || ref="$REMOTE/$BRANCH"
    git archive "$ref" -- "${PATHS[@]}" | tar -x
    echo "tooling-sync: pulled ${PATHS[*]} from $ref onto disk (untracked here)."
    ;;
  save)
    msg="${1:-chore(dev-tooling): sync AI tooling from working copy}"
    wt="$(mktemp -d)"
    trap 'git worktree remove --force "$wt" 2>/dev/null || true' EXIT
    git worktree add -q "$wt" "$BRANCH"
    # Mirror the on-disk tooling into the worktree (rsync respects nothing itself; the
    # committed set is pruned by .claude/.gitignore inside the dev-tooling checkout).
    rsync -a --delete .claude "$wt"/
    cp CLAUDE.md "$wt"/CLAUDE.md
    git -C "$wt" add -A
    if git -C "$wt" diff --cached --quiet; then
      echo "tooling-sync: nothing changed; dev-tooling already up to date."
    else
      git -C "$wt" commit -q -m "$msg"
      git -C "$wt" push -q "$REMOTE" "$BRANCH"
      echo "tooling-sync: committed + pushed to $BRANCH -> $(git -C "$wt" rev-parse --short HEAD)"
    fi
    ;;
  status)
    wt="$(mktemp -d)"
    trap 'git worktree remove --force "$wt" 2>/dev/null || true' EXIT
    git worktree add -q "$wt" "$BRANCH"
    rsync -a --delete .claude "$wt"/ ; cp CLAUDE.md "$wt"/CLAUDE.md
    git -C "$wt" add -A
    git -C "$wt" --no-pager diff --cached --stat || echo "  (in sync)"
    ;;
  ""|-h|--help|help)
    sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *)
    die "unknown command '$cmd' (try: pull | save | status | help)"
    ;;
esac

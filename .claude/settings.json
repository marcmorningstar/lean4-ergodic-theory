{
  "permissions": {
    "allow": [
      "Bash(lake env lean *)",
      "Bash(lake build)",
      "Bash(lake build *)",
      "Bash(python3 *leancheck.py *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(firecrawl search *)",
      "Bash(firecrawl scrape *)",
      "Bash(firecrawl map *)"
    ],
    "deny": [
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(git stash:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/warm-leancheck.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-subagent-git.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-leancheck.py",
            "timeout": 90
          }
        ]
      }
    ]
  }
}

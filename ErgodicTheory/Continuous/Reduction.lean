import ErgodicTheory.Continuous.Flow
import ErgodicTheory.Lyapunov.Extensions.Corollaries
import ErgodicTheory.Cocycle.Norm

/-!
# Reduction of the continuous-flow MET to the discrete theorem

At integer times the continuous-flow Oseledets multiplicative ergodic theorem reduces to the
discrete-time theorem `ErgodicTheory.oseledets_filtration'`.

The continuous-flow data is a measure-preserving flow `φ` (`ErgodicTheory.MeasurePreservingFlow`)
and a continuous-time linear cocycle `A` over it (`ErgodicTheory.FlowCocycle`). The reduction
identity `ErgodicTheory.FlowCocycle.toCocycle_eq` shows that at integer times the continuous-time
cocycle equals the discrete iterated cocycle generated by its time-`1` map `A 1` over the
time-`1` flow map `φ 1`. Hence, once the discrete MET is applied to the generator `A 1` and the
dynamics `φ 1`, an Oseledets filtration for the integer-time continuous cocycle is obtained.

The additional ingredient is the integrability of the time-`1` log-norms. The discrete theorem
requires `log⁺ ‖A 1‖ ∈ L¹(μ)` and `log⁺ ‖(A 1)⁻¹‖ ∈ L¹(μ)`; these follow from a
uniform-on-`[0,1]` integrable dominating function for the continuous family, which is the
natural continuous-flow hypothesis (a continuous-time analogue of the discrete one-sided
integrability assumption).

## Main results

* `ErgodicTheory.integrableLogNorm_timeOne`: the time-`1` map `A 1` has integrable positive
  log-norm, given an integrable function dominating `log⁺ ‖A s‖` uniformly for `s ∈ [0,1]`.
* `ErgodicTheory.integrableLogNorm_timeOne_inv`: the analogous statement for the inverse `(A 1)⁻¹`.
* `ErgodicTheory.exists_isOseledetsFiltration_timeOne`: the discrete MET applied to the time-`1`
  data, yielding an Oseledets filtration for the generator `A 1` over the dynamics `φ 1`.
-/

open MeasureTheory
open scoped Matrix.Norms.L2Operator

namespace ErgodicTheory

variable {X : Type*} [MeasurableSpace X] {d : ℕ} {μ : Measure X}

/-- The positive part of the logarithm is measurable (`log⁺ = fun r => max 0 (log r)`). -/
private theorem measurable_posLog : Measurable Real.posLog :=
  measurable_const.max Real.measurable_log

/-- **Integrability of the time-`1` log-norm.** If an integrable function `g` dominates
`log⁺ ‖A s‖` uniformly over `s ∈ [0,1]` (in particular at `s = 1`), then the time-`1` map
`A 1` of the continuous-time cocycle has integrable positive log-norm, i.e.
`IntegrableLogNorm (A 1 ·) μ`. This is exactly the discrete one-sided integrability hypothesis
for the generator `A 1`. -/
theorem integrableLogNorm_timeOne (φ : MeasurePreservingFlow μ) (A : FlowCocycle φ d)
    {g : X → ℝ} (hg : Integrable g μ)
    (hgb : ∀ s ∈ Set.Icc (0 : ℝ) 1, ∀ x, Real.posLog ‖A s x‖ ≤ g x) :
    IntegrableLogNorm (fun x => A 1 x) μ := by
  refine hg.mono'
    (measurable_posLog.comp (measurable_l2_opNorm.comp (A.measurable 1))).aestronglyMeasurable
    (Filter.Eventually.of_forall fun x => ?_)
  rw [Real.norm_eq_abs, abs_of_nonneg (Real.posLog_nonneg)]
  exact hgb 1 (by norm_num [Set.mem_Icc]) x

/-- **Integrability of the time-`1` inverse log-norm.** If an integrable function `g'`
dominates `log⁺ ‖(A s)⁻¹‖` uniformly over `s ∈ [0,1]` (in particular at `s = 1`), then the
inverse `(A 1)⁻¹` of the time-`1` cocycle map has integrable positive log-norm, i.e.
`IntegrableLogNorm (fun x => (A 1 x)⁻¹) μ`. This is the discrete one-sided integrability
hypothesis for the inverse generator. -/
theorem integrableLogNorm_timeOne_inv (φ : MeasurePreservingFlow μ) (A : FlowCocycle φ d)
    {g' : X → ℝ} (hg' : Integrable g' μ)
    (hg'b : ∀ s ∈ Set.Icc (0 : ℝ) 1, ∀ x, Real.posLog ‖(A s x)⁻¹‖ ≤ g' x) :
    IntegrableLogNorm (fun x => (A 1 x)⁻¹) μ := by
  refine hg'.mono'
    (measurable_posLog.comp (measurable_l2_opNorm.comp
      (measurable_inv_matrix.comp (A.measurable 1)))).aestronglyMeasurable
    (Filter.Eventually.of_forall fun x => ?_)
  rw [Real.norm_eq_abs, abs_of_nonneg (Real.posLog_nonneg)]
  exact hg'b 1 (by norm_num [Set.mem_Icc]) x

/-- **Reduction of the continuous-flow MET to the discrete theorem at integer times.**
Applying the discrete Oseledets theorem `ErgodicTheory.oseledets_filtration'` to the generator
`A 1` over the ergodic time-`1` dynamics `φ 1` yields an Oseledets filtration for the time-`1`
cocycle map. Combined with the reduction identity `ErgodicTheory.FlowCocycle.toCocycle_eq` (which
identifies the integer-time continuous cocycle with the discrete iterated cocycle of `A 1` over
`φ 1`), this gives the integer-time behaviour of the continuous-flow cocycle.

The integrability hypotheses are stated as integrable dominating functions for the continuous
family `log⁺ ‖A s‖` (resp. `log⁺ ‖(A s)⁻¹‖`) uniformly over `s ∈ [0,1]`. -/
theorem exists_isOseledetsFiltration_timeOne [IsProbabilityMeasure μ]
    (φ : MeasurePreservingFlow μ) (herg : Ergodic (φ 1) μ) (A : FlowCocycle φ d)
    {g g' : X → ℝ} (hg : Integrable g μ) (hg' : Integrable g' μ)
    (hgb : ∀ s ∈ Set.Icc (0 : ℝ) 1, ∀ x, Real.posLog ‖A s x‖ ≤ g x)
    (hg'b : ∀ s ∈ Set.Icc (0 : ℝ) 1, ∀ x, Real.posLog ‖(A s x)⁻¹‖ ≤ g' x) :
    ∃ (k : ℕ) (lam : Fin k → ℝ)
      (V : Fin (k + 1) → X → Submodule ℝ (EuclideanSpace ℝ (Fin d))),
      IsOseledetsFiltration μ (φ 1) (fun x => A 1 x) k lam V :=
  oseledets_filtration' herg (fun x => A 1 x) (fun x => A.det_ne_zero 1 x) (A.measurable 1)
    (integrableLogNorm_timeOne φ A hg hgb) (integrableLogNorm_timeOne_inv φ A hg' hg'b)

end ErgodicTheory

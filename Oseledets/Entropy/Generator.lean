import Oseledets.Entropy.KSEntropySystem

/-!
# Generating partitions and the supplied-generator entropy interface

A finite measurable partition `P` of a measure-preserving system `(Œ±, T, Œº)` is a **generator**
(or *generating partition*) when the dynamics, refined under the forward iterates of `T`, recovers
the whole measurable structure: the smallest `T`-pullback-stable œÉ-algebra containing the œÉ-algebra
`œÉ(P)` generated by the cells of `P` is the ambient œÉ-algebra `mŒ±`.

The classical **Kolmogorov‚ÄìSinai theorem** then asserts the entropy reduction
`h(T) = h(P, T)` for any generator `P`: the supremum defining the entropy of the system is already
attained on a single generating partition. Proving that theorem is a substantial undertaking; this
file deliberately does **not** prove it. Following the verified design plan for the
Abramov‚ÄìRokhlin assembly (issue #13), the M6 conditional-entropy layer ships under *supplied*
generator-reduction equalities rather than a generator theorem. Accordingly this file provides the
`IsGenerating` **predicate**, stated in the honest exact-equality œÉ-algebra form, together with
cheap, true API (`œÉ(P) ‚â§ the generated œÉ-algebra`, refinement monotonicity). The generator-reduction
equality `h(T) = h(P, T)` itself is supplied by
`Oseledets.Entropy.ksEntropy_eq_ksEntropyPartition_of_generating`
(`Oseledets.Entropy.GeneratorTheorem`).

## Design note: which œÉ-algebra equation?

The generated invariant œÉ-algebra is taken as `‚®Ü n, comap (T^[n]) œÉ(P)`, the supremum over the
*forward* iterates `T^[n]` of the pulled-back generating œÉ-algebra `œÉ(P) = generateFrom (range
P.cells)`. This is the standard one-sided generator condition for a (possibly non-invertible)
endomorphism: a point's whole `Œº`-essential coordinates are recovered from the observable `P` and
its forward time-translates. The exact equality with `mŒ±` is clean to state and is the form used by
the Kolmogorov‚ÄìSinai theorem; a `‚â§ mŒ±` direction always holds (`IsGenerating` is then the reverse
saturation), so the predicate is genuinely a hypothesis, not a triviality.

## Main definitions

* `Oseledets.Entropy.IsGenerating`: `P` generates the dynamics ‚Äî the smallest forward-`T`-invariant
  œÉ-algebra containing `œÉ(P)` is the ambient œÉ-algebra.

## Main results

* `Oseledets.Entropy.generateFrom_cells_le_generated`: `œÉ(P) ‚â§ ‚®Ü n, comap (T^[n]) œÉ(P)`, the
  cheap inclusion of the static generating œÉ-algebra into the forward-saturated one.
* `Oseledets.Entropy.IsGenerating.le`: a generating partition's forward-saturated œÉ-algebra is the
  ambient œÉ-algebra (unfolded form).

## References

* Fran√ßois Le Ma√Ætre, *Notes on the Kolmogorov‚ÄìSinai theorem* (2017), ¬ß2 (the Kolmogorov‚ÄìSinai
  generator theorem).
* Peter Walters, *An Introduction to Ergodic Theory*, GTM **79**, Springer (1982), Ch. 4.
-/

open MeasureTheory Function MeasurableSpace

namespace Oseledets.Entropy

variable {Œ± : Type*} {Œπ : Type*} [mŒ± : MeasurableSpace Œ±] [Fintype Œπ]

/-- The œÉ-algebra `œÉ(P) = generateFrom (range P.cells)` generated by the cells of a finite
partition `P`. This is the static observable œÉ-algebra: the smallest œÉ-algebra making membership in
each cell of `P` measurable. Marked `@[reducible]` since its value is a `MeasurableSpace` (a class
type), so it must unfold for instance resolution and definitional rewriting. -/
@[reducible]
def generatedSigmaAlgebra (Œº : Measure Œ±) (P : MeasurePartition Œº Œπ) : MeasurableSpace Œ± :=
  MeasurableSpace.generateFrom (Set.range P.cells)

/-- **Reindexing leaves the generated œÉ-algebra unchanged.** The cell family is merely permuted, so
its range ‚Äî and hence the œÉ-algebra it generates ‚Äî is the same. -/
lemma generatedSigmaAlgebra_reindex {Œ∫ : Type*} [Fintype Œ∫] {Œº : Measure Œ±}
    (P : MeasurePartition Œº Œπ) (e : Œ∫ ‚âÉ Œπ) :
    generatedSigmaAlgebra Œº (P.reindex e) = generatedSigmaAlgebra Œº P := by
  have hr : Set.range (P.reindex e).cells = Set.range P.cells :=
    e.surjective.range_comp P.cells
  unfold generatedSigmaAlgebra
  rw [hr]

/-- `P` is a **generating partition** (a *generator*) for the measure-preserving system `(Œ±, T, Œº)`
when the smallest forward-`T`-pullback-stable œÉ-algebra containing the generated œÉ-algebra `œÉ(P)`
is the ambient measurable structure `mŒ±`:
`‚®Ü n, comap (T^[n]) œÉ(P) = mŒ±`.

This is the standard one-sided generator condition for a (possibly non-invertible) endomorphism:
the whole measurable structure is recovered from the observable `P` together with its forward
time-translates `T^[n]`. The Kolmogorov‚ÄìSinai theorem then gives the entropy reduction
`h(T) = h(P, T)`; that theorem is *not* proved here ‚Äî this predicate is the hypothesis the
supplied-generator entropy interface (issue #13, Abramov‚ÄìRokhlin) consumes. -/
def IsGenerating (Œº : Measure Œ±) (T : Œ± ‚Üí Œ±) (P : MeasurePartition Œº Œπ) : Prop :=
  (‚®Ü n : ‚Ñï, MeasurableSpace.comap (T^[n]) (generatedSigmaAlgebra Œº P)) = mŒ±

/-- The static generating œÉ-algebra `œÉ(P)` sits inside the forward-saturated œÉ-algebra
`‚®Ü n, comap (T^[n]) œÉ(P)`: the `n = 0` term is `comap (T^[0]) œÉ(P) = comap id œÉ(P) = œÉ(P)`, which
is bounded above by the supremum. This is the always-available `‚â§` half; `IsGenerating` is the
nontrivial reverse saturation up to the full ambient œÉ-algebra. -/
lemma generateFrom_cells_le_generated (Œº : Measure Œ±) (T : Œ± ‚Üí Œ±) (P : MeasurePartition Œº Œπ) :
    generatedSigmaAlgebra Œº P ‚â§
      ‚®Ü n : ‚Ñï, MeasurableSpace.comap (T^[n]) (generatedSigmaAlgebra Œº P) := by
  refine le_trans (le_of_eq ?_) (le_iSup _ 0)
  rw [Function.iterate_zero, MeasurableSpace.comap_id]

/-- Unfolded form of `IsGenerating`: a generating partition's forward-saturated œÉ-algebra equals
the ambient measurable structure. This is just the definition, named for convenient consumption by
the Abramov‚ÄìRokhlin assembly. -/
lemma IsGenerating.le {Œº : Measure Œ±} {T : Œ± ‚Üí Œ±}
    {P : MeasurePartition Œº Œπ} (h : IsGenerating Œº T P) :
    (‚®Ü n : ‚Ñï, MeasurableSpace.comap (T^[n]) (generatedSigmaAlgebra Œº P)) = mŒ± :=
  h

/-- **Refinement monotonicity of the generated œÉ-algebra.** If the cells of `P` all lie in the
œÉ-algebra generated by a finer partition `Q` (`œÉ(P) ‚â§ œÉ(Q)`), then `Q`'s forward-saturated
œÉ-algebra contains `P`'s. In particular, if `P` already generates the dynamics, so does any
refinement `Q` of `P`. The pullback `comap (T^[n])` is monotone in its œÉ-algebra argument, and
`iSup` is monotone, so the saturation is monotone in `œÉ(¬∑)`. -/
lemma generated_mono {Œº : Measure Œ±} {T : Œ± ‚Üí Œ±} {P Q : MeasurePartition Œº Œπ}
    (hPQ : generatedSigmaAlgebra Œº P ‚â§ generatedSigmaAlgebra Œº Q) :
    (‚®Ü n : ‚Ñï, MeasurableSpace.comap (T^[n]) (generatedSigmaAlgebra Œº P)) ‚â§
      ‚®Ü n : ‚Ñï, MeasurableSpace.comap (T^[n]) (generatedSigmaAlgebra Œº Q) :=
  iSup_mono fun _ => MeasurableSpace.comap_mono hPQ

/-- A refinement of a generator is a generator: if `œÉ(P) ‚â§ œÉ(Q)` and `P` generates, then `Q`
generates. The ambient œÉ-algebra `mŒ±` always dominates `Q`'s forward saturation (each cell of `Q`
is measurable, so `œÉ(Q) ‚â§ mŒ±`, hence every `comap (T^[n]) œÉ(Q) ‚â§ mŒ±`); combined with the lower
bound from `P`'s saturation via `generated_mono`, antisymmetry pins it to `mŒ±`. -/
lemma IsGenerating.mono_refine {Œº : Measure Œ±} {T : Œ± ‚Üí Œ±}
    (hT : Measurable T) {P Q : MeasurePartition Œº Œπ}
    (hPQ : generatedSigmaAlgebra Œº P ‚â§ generatedSigmaAlgebra Œº Q)
    (hP : IsGenerating Œº T P) :
    IsGenerating Œº T Q := by
  -- The generated œÉ-algebra of `Q` is below `mŒ±`: each cell of `Q` is measurable.
  have hQ_le : generatedSigmaAlgebra Œº Q ‚â§ mŒ± := by
    refine MeasurableSpace.generateFrom_le ?_
    rintro s ‚ü®i, rfl‚ü©
    exact Q.measurable i
  -- Hence every forward pullback `comap (T^[n]) œÉ(Q) ‚â§ mŒ±`, so the supremum is `‚â§ mŒ±`.
  have hsup_le : (‚®Ü n : ‚Ñï, MeasurableSpace.comap (T^[n]) (generatedSigmaAlgebra Œº Q)) ‚â§ mŒ± := by
    refine iSup_le fun n => ?_
    exact le_trans (MeasurableSpace.comap_mono hQ_le) (hT.iterate n).comap_le
  -- The reverse direction: `mŒ± = ‚®Ü comap œÉ(P) ‚â§ ‚®Ü comap œÉ(Q)` via `generated_mono`.
  -- Use `hP.ge : mŒ± ‚â§ ‚®Ü comap œÉ(P)` directly (rewriting `mŒ±` would break the `Measure Œ±` type
  -- dependency, since `Œº : @Measure Œ± mŒ±`).
  exact le_antisymm hsup_le (le_trans hP.ge (generated_mono hPQ))

end Oseledets.Entropy
